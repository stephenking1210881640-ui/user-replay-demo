generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ApplicationStatus {
  ACTIVE
  INACTIVE
  PENDING
  CONNECTED
  DEGRADED
}

enum TenantPlan {
  STARTER
  GROWTH
  ENTERPRISE
}

enum TenantStatus {
  ACTIVE
  TRIAL
  RISK
}

enum TagType {
  USER
  JOURNEY
}

enum TagSource {
  SYSTEM
  MANUAL
  RULE
}

enum JourneyResultStatus {
  COMPLETED
  ABANDONED
  FAILED
  BROWSING
}

enum JourneySource {
  DEMO
  REAL
}

enum JourneyEventType {
  PAGE_VIEW
  REGION_ACTION
  BUSINESS_ACTION
  REQUEST
  STATE_CHANGE
  FEEDBACK
  ANOMALY
  EXIT
}

enum EvidenceType {
  SCREENSHOT
  TOAST
  NETWORK
  ERROR_NOTE
  DOM_SNAPSHOT
}

enum EvidenceSeverity {
  INFO
  WARNING
  CRITICAL
}

enum FindingCategory {
  INSIGHT
  INTERACTION
  TECHNICAL
}

model Tenant {
  id                String                      @id @default(cuid())
  name              String
  slug              String                      @unique
  industry          String
  plan              TenantPlan
  status            TenantStatus
  logoUrl           String?
  description       String?
  createdAt         DateTime                    @default(now())
  updatedAt         DateTime                    @updatedAt
  applications      Application[]
  users             User[]
  journeys          Journey[]
  tags              Tag[]
  projects          Project[]
  integrationLogs   IntegrationLog[]
  browserEvents     BrowserEvent[]
  replaySegments    ReplaySegment[]
  aiProfiles        ApplicationAiProfile[]
  journeyAiAnalyses JourneyAiAnalysis[]
  agent1ModelLogs   Agent1ModelInteractionLog[]
  agent2ModelLogs   Agent2ModelInteractionLog[]
  aiModelConfig     TenantAiModelConfig?

  @@index([status, createdAt])
}

model TenantAiModelConfig {
  id        String   @id @default(cuid())
  tenantId  String   @unique
  provider  String
  baseUrl   String
  model     String
  apiKey    String
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([enabled, updatedAt])
  @@map("tenant_ai_model_configs")
}

model Application {
  id                String                      @id @default(cuid())
  tenantId          String
  name              String
  appKey            String
  host              String
  description       String
  status            ApplicationStatus           @default(PENDING)
  ingestToken       String?
  createdAt         DateTime                    @default(now())
  updatedAt         DateTime                    @updatedAt
  lastReportedAt    DateTime?
  tenant            Tenant                      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users             User[]
  tags              Tag[]
  journeys          Journey[]
  projects          Project[]
  integrationLogs   IntegrationLog[]
  browserEvents     BrowserEvent[]
  replaySegments    ReplaySegment[]
  aiProfiles        ApplicationAiProfile[]
  journeyAiAnalyses JourneyAiAnalysis[]
  agent1ModelLogs   Agent1ModelInteractionLog[]
  agent2ModelLogs   Agent2ModelInteractionLog[]

  @@unique([tenantId, appKey])
  @@index([tenantId, createdAt])
}

model User {
  id            String      @id @default(cuid())
  tenantId      String
  applicationId String
  externalId    String
  name          String
  email         String?
  avatarSeed    String
  deviceType    String
  os            String
  browser       String
  location      String?
  firstSeenAt   DateTime
  lastActiveAt  DateTime
  tenant        Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  userTags      UserTag[]
  journeys      Journey[]

  @@unique([tenantId, externalId])
  @@index([tenantId, lastActiveAt])
  @@index([applicationId, lastActiveAt])
}

model Tag {
  id            String       @id @default(cuid())
  tenantId      String
  applicationId String
  name          String
  type          TagType
  source        TagSource    @default(MANUAL)
  color         String
  description   String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @default(now()) @updatedAt
  tenant        Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  application   Application  @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  userTags      UserTag[]
  journeyTags   JourneyTag[]

  @@unique([tenantId, type, name])
  @@index([tenantId, type])
  @@index([applicationId, type])
}

model UserTag {
  id        String   @id @default(cuid())
  userId    String
  tagId     String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tag       Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([userId, tagId])
}

model Journey {
  id                  String                      @id @default(cuid())
  tenantId            String
  applicationId       String
  userId              String
  journeyCode         String                      @unique
  title               String
  startedAt           DateTime
  endedAt             DateTime
  totalDurationMs     Int
  effectiveDurationMs Int
  pageCount           Int
  keyActionCount      Int
  requestCount        Int
  resultStatus        JourneyResultStatus
  hasAnomaly          Boolean                     @default(false)
  pageUrl             String
  pageTemplate        String
  pageTitle           String
  businessActionType  String
  aiSummaryShort      String
  aiScenarioSummary   String
  aiProcessSummary    String
  aiGoalAnalysis      String
  aiAnomalyAnalysis   String
  source              JourneySource               @default(DEMO)
  sessionId           String?
  anonymousId         String?
  externalUserId      String?
  aggregationVersion  String?
  createdAt           DateTime                    @default(now())
  tenant              Tenant                      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  application         Application                 @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  user                User                        @relation(fields: [userId], references: [id], onDelete: Cascade)
  journeyTags         JourneyTag[]
  projectJourneys     ProjectJourney[]
  events              JourneyEvent[]
  evidences           Evidence[]
  browserEvents       BrowserEvent[]
  replaySegments      ReplaySegment[]
  aiAnalyses          JourneyAiAnalysis[]
  agent2ModelLogs     Agent2ModelInteractionLog[]

  @@index([tenantId, startedAt])
  @@index([applicationId, startedAt])
  @@index([userId, startedAt])
  @@index([applicationId, sessionId, startedAt])
  @@index([source, startedAt])
  @@index([pageTemplate])
  @@index([resultStatus, hasAnomaly])
}

model JourneyTag {
  id        String   @id @default(cuid())
  journeyId String
  tagId     String
  createdAt DateTime @default(now())
  journey   Journey  @relation(fields: [journeyId], references: [id], onDelete: Cascade)
  tag       Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([journeyId, tagId])
}

model Project {
  id                   String           @id @default(cuid())
  tenantId             String
  applicationId        String
  projectCode          String?          @unique
  name                 String
  goal                 String
  focusArea            String
  focusTarget          String           @default("")
  focusFeature         String           @default("")
  ownerName            String
  description          String
  filterTimeRangeLabel String?
  filterPageTemplates  String?
  filterStatuses       String?
  filterTagRules       String?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  tenant               Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  application          Application      @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  projectJourneys      ProjectJourney[]
  findings             ProjectFinding[]

  @@index([tenantId, createdAt])
  @@index([applicationId, createdAt])
}

model ProjectJourney {
  id        String   @id @default(cuid())
  projectId String
  journeyId String
  addedAt   DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  journey   Journey  @relation(fields: [journeyId], references: [id], onDelete: Cascade)

  @@unique([projectId, journeyId])
}

model JourneyEvent {
  id                   String           @id @default(cuid())
  journeyId            String
  sourceBrowserEventId String?
  seq                  Int
  occurredAt           DateTime
  offsetMs             Int
  type                 JourneyEventType
  title                String
  description          String
  pageUrl              String?
  pageTemplate         String?
  pageTitle            String?
  region               String?
  regionSource         String?
  regionConfidence     Float?
  uiAction             String?
  actionType           String?
  businessAction       String?
  businessIntent       String?
  targetLabel          String?
  targetSelector       String?
  targetRole           String?
  targetText           String?
  targetTagName        String?
  targetTestId         String?
  targetData           Json?
  targetRect           Json?
  viewport             Json?
  scroll               Json?
  interaction          Json?
  semanticPayload      Json?
  aiRegionStatus       String?
  aiRegionSuggestion   Json?
  aiRegionReason       String?
  replaySegmentId      String?
  replayOffsetMs       Int?
  requestId            String?
  requestUrl           String?
  requestHost          String?
  method               String?
  pathTemplate         String?
  statusCode           Int?
  durationMs           Int?
  requestOutcome       String?
  uiFeedback           String?
  isKeyEvent           Boolean          @default(true)
  isAnomaly            Boolean          @default(false)
  journey              Journey          @relation(fields: [journeyId], references: [id], onDelete: Cascade)
  evidences            Evidence[]

  @@unique([journeyId, seq])
  @@index([journeyId, occurredAt])
  @@index([sourceBrowserEventId])
  @@index([region])
  @@index([uiAction])
  @@index([businessAction])
  @@index([aiRegionStatus])
  @@index([replaySegmentId])
}

model Evidence {
  id             String           @id @default(cuid())
  journeyId      String
  journeyEventId String?
  type           EvidenceType
  title          String
  description    String
  severity       EvidenceSeverity
  imageUrl       String?
  content        String?
  capturedAt     DateTime
  offsetMs       Int
  journey        Journey          @relation(fields: [journeyId], references: [id], onDelete: Cascade)
  journeyEvent   JourneyEvent?    @relation(fields: [journeyEventId], references: [id], onDelete: SetNull)

  @@index([journeyId, offsetMs])
}

model JourneyAiAnalysis {
  id                   String                      @id @default(cuid())
  tenantId             String
  applicationId        String
  journeyId            String
  goal                 String
  goalConfidence       Float
  processSummary       String
  outcomeStatus        String
  outcomeReason        String
  outcomeConfidence    Float
  keyStagesJson        Json
  blockersJson         Json
  anomaliesJson        Json
  evidenceJson         Json
  insightsJson         Json
  agent1RulesJson      Json?
  modelVersion         String                      @default("agent2-rules-v1")
  generatedAt          DateTime                    @default(now())
  createdAt            DateTime                    @default(now())
  tenant               Tenant                      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  application          Application                 @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  journey              Journey                     @relation(fields: [journeyId], references: [id], onDelete: Cascade)
  modelInteractionLogs Agent2ModelInteractionLog[]

  @@index([tenantId, generatedAt])
  @@index([applicationId, generatedAt])
  @@index([journeyId, generatedAt])
  @@map("journey_ai_analyses")
}

model Agent2ModelInteractionLog {
  id                String             @id @default(cuid())
  tenantId          String
  applicationId     String
  journeyId         String
  analysisId        String?
  provider          String
  model             String
  baseUrl           String?
  promptVersion     String
  status            String
  generationMode    String
  inputSystemPrompt String
  inputUserPrompt   String
  responseText      String?
  responseJson      Json?
  parsedOutputJson  Json?
  errorMessage      String?
  latencyMs         Int?
  tokenUsageJson    Json?
  createdAt         DateTime           @default(now())
  tenant            Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  application       Application        @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  journey           Journey            @relation(fields: [journeyId], references: [id], onDelete: Cascade)
  analysis          JourneyAiAnalysis? @relation(fields: [analysisId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([applicationId, createdAt])
  @@index([journeyId, createdAt])
  @@index([analysisId])
  @@map("agent2_model_interaction_logs")
}

model IntegrationLog {
  id             String      @id @default(cuid())
  tenantId       String
  applicationId  String
  level          String
  status         String
  source         String
  message        String
  payloadSummary String?
  createdAt      DateTime    @default(now())
  tenant         Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  application    Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
  @@index([applicationId, createdAt])
}

model ApplicationAiProfile {
  id                      String                      @id @default(cuid())
  tenantId                String
  applicationId           String
  sourceUrl               String
  businessHint            String?
  appPurpose              String
  appSummary              String
  pageMapJson             Json
  regionsJson             Json
  interactiveElementsJson Json
  journeysJson            Json
  successRulesJson        Json
  failureRulesJson        Json
  sdkRecommendationsJson  Json
  confidenceNotesJson     Json
  crawlMetadataJson       Json
  inputSnapshotJson       Json?
  modelOutputJson         Json?
  modelMetadataJson       Json?
  provider                String?
  model                   String?
  promptVersion           String?
  generationMode          String                      @default("heuristic")
  fallbackUsed            Boolean                     @default(false)
  version                 String                      @default("agent1-v1")
  generatedAt             DateTime                    @default(now())
  createdAt               DateTime                    @default(now())
  tenant                  Tenant                      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  application             Application                 @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  modelInteractionLogs    Agent1ModelInteractionLog[]

  @@index([tenantId, generatedAt])
  @@index([applicationId, generatedAt])
  @@map("application_ai_profiles")
}

model Agent1ModelInteractionLog {
  id                String                @id @default(cuid())
  tenantId          String
  applicationId     String
  profileId         String?
  provider          String
  model             String
  baseUrl           String?
  promptVersion     String
  status            String
  generationMode    String
  inputSystemPrompt String
  inputUserPrompt   String
  responseText      String?
  responseJson      Json?
  parsedOutputJson  Json?
  errorMessage      String?
  latencyMs         Int?
  tokenUsageJson    Json?
  createdAt         DateTime              @default(now())
  tenant            Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  application       Application           @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  profile           ApplicationAiProfile? @relation(fields: [profileId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([applicationId, createdAt])
  @@index([profileId])
  @@map("agent1_model_interaction_logs")
}

model BrowserEvent {
  id                String      @id @default(cuid())
  tenantId          String
  applicationId     String
  appKey            String
  eventId           String
  sessionId         String
  userId            String?
  anonymousId       String?
  eventType         String
  timestamp         DateTime
  pageUrl           String?
  pageHost          String?
  pagePath          String?
  pageTemplate      String?
  pageTitle         String?
  referrer          String?
  region            String?
  regionSource      String?
  regionConfidence  Float?
  action            String?
  actionType        String?
  businessAction    String?
  businessIntent    String?
  targetLabel       String?
  targetSelector    String?
  targetRole        String?
  targetText        String?
  targetTagName     String?
  targetTestId      String?
  targetData        Json?
  targetRect        Json?
  viewport          Json?
  scroll            Json?
  interaction       Json?
  semanticPayload   Json?
  aiRegionStatus    String?
  aiRegionCandidate Json?
  aiRegionReason    String?
  requestUrl        String?
  requestHost       String?
  requestMethod     String?
  requestStatus     Int?
  requestDuration   Int?
  requestId         String?
  context           Json?
  rawPayload        Json
  journeyId         String?
  aggregatedAt      DateTime?
  receivedAt        DateTime    @default(now())
  tenant            Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  application       Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  journey           Journey?    @relation(fields: [journeyId], references: [id], onDelete: SetNull)

  @@unique([applicationId, eventId])
  @@index([tenantId, receivedAt])
  @@index([applicationId, receivedAt])
  @@index([tenantId, aggregatedAt])
  @@index([journeyId])
  @@index([sessionId, timestamp])
  @@index([eventType, timestamp])
  @@index([region])
  @@index([action])
  @@index([businessAction])
  @@index([aiRegionStatus])
}

model ReplaySegment {
  id            String      @id @default(cuid())
  tenantId      String
  applicationId String
  journeyId     String?
  sessionId     String
  anonymousId   String?
  userId        String?
  segmentId     String
  source        String      @default("rrweb")
  schemaVersion String      @default("rrweb-v1")
  startedAt     DateTime
  endedAt       DateTime?
  eventCount    Int         @default(0)
  payload       Json
  compressed    Boolean     @default(false)
  encoding      String?
  receivedAt    DateTime    @default(now())
  tenant        Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  journey       Journey?    @relation(fields: [journeyId], references: [id], onDelete: SetNull)

  @@unique([applicationId, segmentId])
  @@index([tenantId, receivedAt])
  @@index([applicationId, sessionId, startedAt])
  @@index([journeyId])
}

model ProjectFinding {
  id                   String          @id @default(cuid())
  projectId            String
  title                String
  summary              String
  category             FindingCategory
  evidenceJourneyCount Int
  sortOrder            Int
  createdAt            DateTime        @default(now())
  project              Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, sortOrder])
}
