generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ApplicationStatus {
  CONNECTED
  DEGRADED
  PENDING
}

enum TenantPlan {
  STARTER
  GROWTH
  ENTERPRISE
}

enum TenantStatus {
  ACTIVE
  TRIAL
  RISK
}

enum TagType {
  USER
  JOURNEY
}

enum TagSource {
  SYSTEM
  MANUAL
  RULE
}

enum JourneyResultStatus {
  COMPLETED
  ABANDONED
  FAILED
  BROWSING
}

enum JourneyEventType {
  PAGE_VIEW
  REGION_ACTION
  BUSINESS_ACTION
  REQUEST
  STATE_CHANGE
  FEEDBACK
  ANOMALY
  EXIT
}

enum EvidenceType {
  SCREENSHOT
  TOAST
  NETWORK
  ERROR_NOTE
  DOM_SNAPSHOT
}

enum EvidenceSeverity {
  INFO
  WARNING
  CRITICAL
}

enum FindingCategory {
  INSIGHT
  INTERACTION
  TECHNICAL
}

model Tenant {
  id           String          @id @default(cuid())
  name         String
  slug         String          @unique
  industry     String
  plan         TenantPlan
  status       TenantStatus
  logoUrl      String?
  description  String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  applications Application[]
  users        User[]
  journeys     Journey[]
  tags         Tag[]
  projects     Project[]
  integrationLogs IntegrationLog[]

  @@index([status, createdAt])
}

model Application {
  id              String            @id @default(cuid())
  tenantId        String
  name            String
  appKey          String
  host            String
  description     String
  status          ApplicationStatus @default(CONNECTED)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  lastReportedAt  DateTime?
  tenant          Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users           User[]
  tags            Tag[]
  journeys        Journey[]
  projects        Project[]
  integrationLogs IntegrationLog[]

  @@unique([tenantId, appKey])
  @@index([tenantId, createdAt])
}

model User {
  id            String      @id @default(cuid())
  tenantId      String
  applicationId String
  externalId    String
  name          String
  email         String?
  avatarSeed    String
  deviceType    String
  os            String
  browser       String
  location      String?
  firstSeenAt   DateTime
  lastActiveAt  DateTime
  tenant        Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  userTags      UserTag[]
  journeys      Journey[]

  @@unique([tenantId, externalId])
  @@index([tenantId, lastActiveAt])
  @@index([applicationId, lastActiveAt])
}

model Tag {
  id            String       @id @default(cuid())
  tenantId      String
  applicationId String
  name          String
  type          TagType
  source        TagSource    @default(MANUAL)
  color         String
  description   String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @default(now()) @updatedAt
  tenant        Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  application   Application  @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  userTags      UserTag[]
  journeyTags   JourneyTag[]

  @@unique([tenantId, type, name])
  @@index([tenantId, type])
  @@index([applicationId, type])
}

model UserTag {
  id        String   @id @default(cuid())
  userId    String
  tagId     String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tag       Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([userId, tagId])
}

model Journey {
  id                  String              @id @default(cuid())
  tenantId            String
  applicationId       String
  userId              String
  journeyCode         String              @unique
  title               String
  startedAt           DateTime
  endedAt             DateTime
  totalDurationMs     Int
  effectiveDurationMs Int
  pageCount           Int
  keyActionCount      Int
  requestCount        Int
  resultStatus        JourneyResultStatus
  hasAnomaly          Boolean             @default(false)
  pageUrl             String
  pageTemplate        String
  pageTitle           String
  businessActionType  String
  aiSummaryShort      String
  aiScenarioSummary   String
  aiProcessSummary    String
  aiGoalAnalysis      String
  aiAnomalyAnalysis   String
  createdAt           DateTime            @default(now())
  tenant              Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  application         Application         @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  user                User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  journeyTags         JourneyTag[]
  projectJourneys     ProjectJourney[]
  events              JourneyEvent[]
  evidences           Evidence[]

  @@index([tenantId, startedAt])
  @@index([applicationId, startedAt])
  @@index([userId, startedAt])
  @@index([pageTemplate])
  @@index([resultStatus, hasAnomaly])
}

model JourneyTag {
  id        String   @id @default(cuid())
  journeyId String
  tagId     String
  createdAt DateTime @default(now())
  journey   Journey  @relation(fields: [journeyId], references: [id], onDelete: Cascade)
  tag       Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([journeyId, tagId])
}

model Project {
  id                   String           @id @default(cuid())
  tenantId             String
  applicationId        String
  projectCode          String?          @unique
  name                 String
  goal                 String
  focusArea            String
  focusTarget          String           @default("")
  focusFeature         String           @default("")
  ownerName            String
  description          String
  filterTimeRangeLabel String?
  filterPageTemplates  String?
  filterStatuses       String?
  filterTagRules       String?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  tenant               Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  application          Application      @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  projectJourneys      ProjectJourney[]
  findings             ProjectFinding[]

  @@index([tenantId, createdAt])
  @@index([applicationId, createdAt])
}

model ProjectJourney {
  id        String   @id @default(cuid())
  projectId String
  journeyId String
  addedAt   DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  journey   Journey  @relation(fields: [journeyId], references: [id], onDelete: Cascade)

  @@unique([projectId, journeyId])
}

model JourneyEvent {
  id             String           @id @default(cuid())
  journeyId      String
  seq            Int
  occurredAt     DateTime
  offsetMs       Int
  type           JourneyEventType
  title          String
  description    String
  pageUrl        String?
  pageTemplate   String?
  pageTitle      String?
  region         String?
  regionSource   String?
  uiAction       String?
  businessAction String?
  businessIntent String?
  targetLabel    String?
  requestHost    String?
  method         String?
  pathTemplate   String?
  statusCode     Int?
  durationMs     Int?
  requestOutcome String?
  uiFeedback     String?
  isKeyEvent     Boolean          @default(true)
  isAnomaly      Boolean          @default(false)
  journey        Journey          @relation(fields: [journeyId], references: [id], onDelete: Cascade)
  evidences      Evidence[]

  @@unique([journeyId, seq])
  @@index([journeyId, occurredAt])
}

model Evidence {
  id             String           @id @default(cuid())
  journeyId      String
  journeyEventId String?
  type           EvidenceType
  title          String
  description    String
  severity       EvidenceSeverity
  imageUrl       String?
  content        String?
  capturedAt     DateTime
  offsetMs       Int
  journey        Journey          @relation(fields: [journeyId], references: [id], onDelete: Cascade)
  journeyEvent   JourneyEvent?    @relation(fields: [journeyEventId], references: [id], onDelete: SetNull)

  @@index([journeyId, offsetMs])
}

model IntegrationLog {
  id             String      @id @default(cuid())
  tenantId       String
  applicationId  String
  level          String
  status         String
  source         String
  message        String
  payloadSummary String?
  createdAt      DateTime    @default(now())
  tenant         Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  application    Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
  @@index([applicationId, createdAt])
}

model ProjectFinding {
  id                   String          @id @default(cuid())
  projectId            String
  title                String
  summary              String
  category             FindingCategory
  evidenceJourneyCount Int
  sortOrder            Int
  createdAt            DateTime        @default(now())
  project              Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, sortOrder])
}
